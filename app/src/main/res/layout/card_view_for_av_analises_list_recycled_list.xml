<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:fab="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <android.support.v7.widget.CardView
        android:id="@+id/cv_av_analises_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            style="?attr/tvListItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/ll_cv_av_analises_list">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tv_AV_AnalisesTypesMTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textStyle="bold"/>

                <TextView
                    style="?attr/lvMainList"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:id="@+id/tv_AVTitleDevider"
                    android:layout_marginLeft="@dimen/devider_margin"
                    android:layout_marginRight="@dimen/devider_margin" />

                <TextView
                    android:id="@+id/tv_AV_Ref_VisitsView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="67dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_gravity="center_vertical"
                    android:textStyle="italic"
                    android:singleLine="true"
                    android:hint="@string/analisis_visits_fragment_directions_hint_ref_visit"/>

            </LinearLayout>

            <TextView
                style="?attr/lvMainList"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/devider_margin"
                android:layout_marginBottom="@dimen/devider_margin"/>


            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginRight="6dp"
                android:layout_marginLeft="6dp"
                android:id="@+id/btn_item_AV_AnalisesTypesM"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:layout_gravity="center_vertical"/>

        </LinearLayout>

    </android.support.v7.widget.CardView>

</RelativeLayout>