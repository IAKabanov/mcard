<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:style="http://schemas.android.com/tools">

    <android.support.v7.widget.CardView
        android:id="@+id/cv_an_visits_mcard_main_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            style="?attr/tvListItem"
            android:id="@+id/ll_cv_an_visits_mcard_main_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clickable="true">

            <LinearLayout
                android:id="@+id/ll_an_visits_mcard_main_list_nested_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tv_an_visits_mcard_main_list_an_visits_id"
                    android:layout_width="1px"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:visibility="invisible"/>

                <TextView
                    android:id="@+id/tv_an_visits_mcard_main_list_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="@dimen/filds_padding_left"
                    android:singleLine="true"
                    android:layout_weight="8"/>

                <TextView
                    android:id="@+id/tv_an_visits_mcard_main_list_top_divider"
                    android:layout_width="1dp"
                    android:layout_height="wrap_content" /> <!-- style="?attr/lvMainList" -->

                <TextView
                    android:id="@+id/tv_an_visits_mcard_main_list_analisis_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="@dimen/filds_padding_left"
                    android:layout_weight="2"
                    android:singleLine="true"/>

            </LinearLayout>

            <TextView
                style="?attr/lvMainList"
                android:id="@+id/tv_an_visits_mcard_main_list_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginLeft="@dimen/devider_margin"
                android:layout_marginRight="@dimen/devider_margin" />

            <LinearLayout
                android:id="@+id/ll_an_visits_mcard_main_list_nested_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tv_an_visits_mcard_main_list_clinic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="@dimen/filds_padding_left_bottom_string"
                    android:layout_weight="6" />

            </LinearLayout>

        </LinearLayout>

    </android.support.v7.widget.CardView>

</RelativeLayout>