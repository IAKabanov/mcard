<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MVisitActivity">

    <android.support.design.widget.AppBarLayout
        app:theme="?attr/toolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/appBarLayout_visit_m"
        android:layout_alignParentStart="false"
        android:layout_alignParentTop="false"
        android:measureWithLargestChild="false">

        <android.support.v7.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/toolbar_visit_m"
            android:minHeight="?attr/actionBarSize"
            android:fitsSystemWindows="true"
            app:title="@string/title_activity_visit">
        </android.support.v7.widget.Toolbar>

        <android.support.design.widget.TabLayout
            app:theme="?attr/visitsTabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tabLayout_visit_m"
            app:tabMode="scrollable"
            app:tabGravity="center"
            app:tabTextAppearance="@style/TabLayoutStyle">
        </android.support.design.widget.TabLayout>

    </android.support.design.widget.AppBarLayout>
    
    <android.support.v4.view.ViewPager
        app:theme="?attr/lvMainList"
        android:id="@+id/viewPager_visit_m"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/appBarLayout_visit_m"
        android:layout_alignParentEnd="false" />

</RelativeLayout>