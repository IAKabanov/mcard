<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:style="http://schemas.android.com/tools">

    <android.support.v7.widget.CardView
        android:id="@+id/cv_visits_cures_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            style="?attr/tvListItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/rl_cv_visits_cures_list">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                >

                <TextView
                    android:id="@+id/tv_VisitsCuresTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_alignParentStart="true"
                    android:textStyle="bold"/>

                <TextView
                    style="?attr/lvMainList"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:id="@+id/tv_VisitsCuresTitleDevider"
                    android:layout_marginLeft="@dimen/devider_margin"
                    android:layout_marginRight="@dimen/devider_margin"
                    android:layout_below="@+id/tv_VisitsCuresTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:layout_below="@+id/tv_VisitsCuresTitleDevider"
                    android:layout_alignParentEnd="true">

                    <TextView
                        android:id="@+id/tv_FragmentCures_VisitsView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="46dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:layout_toLeftOf="@+id/btn_browse_item_CuresVisit" />

                    <ImageButton
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:id="@+id/btn_browse_item_CuresVisit"
                        android:src="@mipmap/btn_browse_black"
                        android:background="@android:color/transparent"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="8dp"
                        android:layout_toLeftOf="@+id/btn_edit_CuresVisit" />

                    <ImageButton
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:id="@+id/btn_edit_CuresVisit"
                        android:src="@mipmap/btn_edit_black"
                        android:background="@android:color/transparent"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center_vertical"
                        android:layout_marginRight="8dp"
                        android:layout_alignParentEnd="true" />

                </LinearLayout>

            </RelativeLayout>

            <TextView
                style="?attr/lvMainList"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/devider_margin"
                android:layout_marginBottom="@dimen/devider_margin"/>

            <ImageButton
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginRight="6dp"
                android:layout_marginLeft="6dp"
                android:id="@+id/btn_Visists_CuresItem"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:src="@mipmap/btn_delete_black"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

    </android.support.v7.widget.CardView>

</RelativeLayout>