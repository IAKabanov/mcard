<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:weightSum="100"
    style="?attr/mainListItemBackground">
    <!--    style="?attr/tvListItem"  -->
<!--    android:background="@drawable/standart_green_main_list_item_background" -->


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/lrm_adapter_type_of_visit"
            android:layout_width="1px"
            android:layout_height="wrap_content"
            android:textColor="@color/color_standart_green_title"
            android:singleLine="true"
            android:visibility="invisible">
        </TextView>

        <TextView
            android:id="@+id/lrm_adapter_id"
            android:layout_width="1px"
            android:layout_height="wrap_content"
            android:textColor="@color/color_standart_green_title"
            android:singleLine="true"
            android:visibility="invisible">
        </TextView>

        <TextView
            android:id="@+id/lrm_adapter_date"
            android:layout_width="12dp"
            android:layout_height="wrap_content"
            android:text="date"
            android:layout_weight="6"
            android:singleLine="true">
        </TextView>

        <TextView
            android:id="@+id/lrm_adapter_specialization"
            android:layout_width="26dp"
            android:layout_height="wrap_content"
            android:text="specialization"
            android:layout_weight="18"
            android:singleLine="true">
        </TextView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/lrm_adapter_empty"
            android:layout_width="6dp"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_weight="6"
            android:singleLine="true">
        </TextView>

        <TextView
            android:id="@+id/lrm_adapter_clinik"
            android:layout_width="14dp"
            android:layout_height="wrap_content"
            android:text="clinik"
            android:layout_weight="25"
            android:singleLine="true">
        </TextView>

        <TextView
            android:id="@+id/lrm_adapter_doctor"
            android:layout_width="38dp"
            android:layout_height="wrap_content"
            android:text="doctor"
            android:layout_weight="30"
            android:singleLine="true">
        </TextView>

    </LinearLayout>

</LinearLayout>
