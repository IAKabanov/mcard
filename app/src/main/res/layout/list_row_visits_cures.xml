<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    style="?attr/tvListItem">

   <TextView
       android:id="@+id/lrvc_adapter_cures_id"
       android:layout_width="1dp"
       android:layout_height="wrap_content"
       android:visibility="invisible"
       android:singleLine="true">
   </TextView>

   <TextView
       android:id="@+id/lrvc_adapter_cures_name"
       android:layout_width="150dp"
       android:layout_height="wrap_content"
       android:text="@string/lrvc_cures_name"
       android:singleLine="true"
       android:layout_gravity="center_vertical|left"
       android:gravity="center_vertical">
   </TextView>

    <TextView
        android:id="@+id/lrvc_adapter_cures_descr"
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:text="@string/lrvc_cures_descr"
        android:singleLine="true"
        android:layout_gravity="center_vertical|left"
        android:gravity="center_vertical">
    </TextView>

</LinearLayout>
