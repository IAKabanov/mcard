<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="ru.kai.mcard.presentation.view.activity.SpecializationActivity">

    <android.support.design.widget.AppBarLayout
        android:id="@+id/mSpecializationAppBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:theme="?attr/toolBar">

        <android.support.v7.widget.Toolbar
            android:id="@+id/mSpecializationToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true"

            app:title="@string/specializations_title_activity">
        </android.support.v7.widget.Toolbar>
        
    </android.support.design.widget.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="true">

        <FrameLayout
            android:id="@+id/SpecializationActivityContainerList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/SpecializationActivityContainerDetail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

    </LinearLayout>

</LinearLayout>


