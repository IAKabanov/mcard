<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <android.support.v7.widget.CardView
        android:id="@+id/cvDubbleCommonCardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            style="?attr/tvListItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:id="@+id/llDubbleCommonCardView">

            <TextView
                android:id="@+id/tvDubbleCommonCardViewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="16dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:textStyle="bold"/>

            <TextView
                style="?attr/lvMainList"
                android:id="@+id/tvDubbleCommonCardViewDevider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginLeft="@dimen/devider_margin"
                android:layout_marginRight="@dimen/devider_margin" />

            <TextView
                android:id="@+id/tvDubbleCommonCardViewDescr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="46dp"
                android:singleLine="true"/>

        </LinearLayout>

    </android.support.v7.widget.CardView>

</RelativeLayout>