<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="?attr/mainBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="ru.kai.mcard.presentation.view.fragment.SpecializationsDetailsFragment">

    <android.support.design.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <android.support.design.widget.TextInputLayout
            android:id="@+id/editSpecializationNameTILayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/filds_margin_36"
            android:theme="?attr/floatingLabelStyle">

            <EditText
                android:id="@+id/editSpecializationName"
                style="?attr/editTextPlusStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/filds_margin"
                android:layout_marginRight="@dimen/filds_margin"
                android:ems="10"
                android:hint="@string/common_caption"
                android:inputType="text" />

        </android.support.design.widget.TextInputLayout>

        <include layout="@layout/view_progress" />

    </android.support.design.widget.CoordinatorLayout>

</FrameLayout>

