<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <android.support.v7.widget.CardView
        android:id="@+id/cvSingleRadioCardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            style="?attr/tvListItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/llSingleRadioCardView">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/imgSingleRadioCardView"
                android:paddingLeft="@dimen/filds_margin_8"
                android:paddingRight="@dimen/filds_margin_8"
                android:src="@drawable/ic_radio_button_unchecked_black_24dp_vector" />

            <TextView
                android:id="@+id/tvSingleRadioCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_alignParentStart="true"
                android:singleLine="true"
                android:textStyle="bold"/>

        </LinearLayout>

    </android.support.v7.widget.CardView>

</RelativeLayout>