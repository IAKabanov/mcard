        <!--<item name="android:background">@color/color_standart_green_main_list_top</item>-->

        <!--<item name="fontPath">fonts/Roboto-MediumItalic.ttf</item>-->
        <item name="fontPath">fonts/Roboto-Regular.ttf</item>
        <!--<item name="android:textAppearance">@style/TextAppearance.FontPath</item>-->

        <item name="android:textSize">@dimen/edit_text_plus_label_text_size_16sp</item>
        <item name="android:singleLine">true</item>

        <!--<item name="android:shadowColor">#000000</item>-->
        <!--<item name="android:shadowRadius">0.1</item>-->
        <!--<item name="android:shadowDx">0.1</item>-->
        <!--<item name="android:shadowDy">0.1</item>-->

    </style>

    <!--<style name="FloatingLabel" parent="TextAppearance.AppCompat">-->
    <style name="FloatingLabelBaseStyle" parent="ThemeOverlay.AppCompat.Light">
        <!-- Hint color and label color in FALSE state -->
        <!--<item name="android:textColorHint">@color/color_standart_green_shadow</item>-->
        <item name="android:textSize">12sp</item>
        <!-- Label color in TRUE state and bar color FALSE and TRUE State -->
