    //**********************************************************
    // cardview
    <style name="SimpleCardView" parent="CardView">
        <item name="cardCornerRadius">2dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="contentPaddingBottom">8dp</item>
        <item name="contentPaddingTop">8dp</item>
        <item name="contentPaddingLeft">20dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">?attr/cvSimpleCardViewBackground</item>
    </style>

    <style name="SimpleCardViewLL">
        <item name="android:background">@drawable/standart_green_list_item_background</item>
    </style>
    <style name="SimpleCardViewText" parent="@android:style/Widget.TextView">
        <item name="fontPath">fonts/Roboto-Regular.ttf</item>
        <item name="android:textSize">@dimen/edit_text_for_list_text_size_17sp</item>
    </style>
    //**********************************************************
    // кнопки

    <style name="ButtonStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/color_standart_green_title</item>
        <item name="android:textStyle">normal</item>
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowRadius">0.1</item>
        <item name="android:shadowDx">0.3</item>
        <item name="android:shadowDy">0.3</item>
        <item name="android:background">@drawable/standart_green_button_background</item>
    </style>

    <style name="ButtonSmallStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowRadius">0.1</item>
        <item name="android:shadowDx">0.3</item>
        <item name="android:shadowDy">0.3</item>
    </style>


