<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimaryGreen</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkGreen</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!--for Shared element transition-->
        <item name="android:windowContentTransitions">true</item>

    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

    </style>

    <style name="AppTheme.ProgressBar">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:visibility">visible</item>
    </style>

    <style name="TabLayoutStyle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">13sp</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="AppTheme.NoActionBar.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.NoActionBar.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    //**********************************************************
    <style name="FullscreenTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:actionBarStyle">@style/FullscreenActionBarStyle</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:windowBackground">@null</item>
        <item name="metaButtonBarStyle">?android:attr/buttonBarStyle</item>
        <item name="metaButtonBarButtonStyle">?android:attr/buttonBarButtonStyle</item>
    </style>

    <style name="FullscreenActionBarStyle" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black_overlay</item>
    </style>

    //**********************************************************
    <style name="PopupMenu" parent="@android:style/Widget.PopupMenu">

    </style>

    //**********************************************************
    <style name="StandartTheme" parent="AppTheme.NoActionBar">
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>

    </style>

    //**********************************************************

    <style name="TitleTextView" parent="@android:style/Widget.TextView">
        <item name="android:shadowColor">@color/color_standart_green_title</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:shadowDx">1.5</item>
        <item name="android:shadowDy">1.5</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/color_standart_green_title</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">normal</item>
        <!--<item name="android:typeface">serif</item>-->
        <item name="fontPath">fonts/Roboto-Black.ttf</item>
<!--        <item name="android:typeface">serif</item>  roboto noto -->
    </style>

    <style name="TitleMainTextView" parent="TitleTextView">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TitleVisitsTextView" parent="TitleTextView">
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TitleParamsTextView" parent="TitleTextView">
        <item name="android:textSize">16sp</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
    </style>

    <style name="allListView">
        <item name="android:background">@drawable/standart_green_lists_background</item>
        <item name="android:layoutAnimation">@anim/layout_bottom_to_top_slide</item>
        <item name="android:dividerHeight">0sp</item>
    </style>

    <style name="ListTextView" parent="@android:style/Widget.TextView">
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowRadius">0.1</item>
        <item name="android:shadowDx">0.1</item>
        <item name="android:shadowDy">0.1</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/color_standart_green_title</item>
        <item name="android:paddingTop">4sp</item>
        <item name="android:paddingBottom">3sp</item>
        <item name="android:singleLine">true</item>
        <item name="android:background">@drawable/standart_green_list_item_background</item>
    </style>

    <style name="CaptionsTextView" parent="@android:style/Widget.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/color_standart_green_title</item>
        <item name="android:textStyle">bold</item>
<!--        <item name="android:typeface">serif</item>-->
    </style>

    <style name="StyleEditsView">
        <item name="android:textSize">16sp</item>
       <!-- <item name="android:background">@drawable/standart_green_filds_background</item>-->
    </style>



    <style name="TextAppearance.FontPath" parent="android:TextAppearance">
        <!-- Custom Attr-->
        <!-- <item name="fontPath">fonts/RobotoCondensed-Regular.ttf</item> -->

        <item name="fontPath">fonts/RobotoCondensed-BoldItalic.ttf</item>
    </style>

    <!--<style name="newEditTextPlusBaseStyle" parent="android:Widget.EditText">-->
    <style name="newEditTextPlusBaseStyle" parent="Widget.AppCompat.EditText">
    <!--<style name="newEditTextPlusBaseStyle">-->
        <!--<item name="android:background">?attr/editTextBackground</item>               editTextBackground     -->
